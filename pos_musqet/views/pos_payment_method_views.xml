<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_musqet" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.musqet</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_payment_terminal']" position="after">
                <!-- Musqet -->
                <field name="musqet_api_key"
                       invisible="use_payment_terminal != 'musqet'"
                       required="use_payment_terminal == 'musqet'"
                       password="True"/>
                <field name="musqet_base_url"
                       invisible="use_payment_terminal != 'musqet'"
                       required="use_payment_terminal == 'musqet'"/>
                <field name="musqet_terminal_serial"
                       invisible="use_payment_terminal != 'musqet'"
                       required="use_payment_terminal == 'musqet'"/>
                <!-- Webhook (optional; public-HTTPS deployments only — the pilot uses polling) -->
                <field name="musqet_webhook_secret"
                       invisible="use_payment_terminal != 'musqet'"
                       password="True"/>
                <field name="musqet_webhook_url"
                       invisible="use_payment_terminal != 'musqet'"/>
            </xpath>
        </field>
    </record>
</odoo>
